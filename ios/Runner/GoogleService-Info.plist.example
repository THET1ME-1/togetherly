<?xml version="1.0" encoding="UTF-8"?>
<!--
  ШАБЛОН. Скопируйте в GoogleService-Info.plist и подставьте значения СВОЕГО
  Firebase-проекта (Firebase Console → Project settings → ваше iOS-приложение →
  «GoogleService-Info.plist»). Реальный файл в git НЕ коммитится (.gitignore).

  Firebase в Togetherly — легаси (проект переезжает на PocketBase). Клиентские
  ключи Firebase не являются секретами, но это ключи ПРОЕКТА автора — не светите
  их, заведите собственный проект.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CLIENT_ID</key>
	<string>YOUR_CLIENT_ID.apps.googleusercontent.com</string>
	<key>REVERSED_CLIENT_ID</key>
	<string>com.googleusercontent.apps.YOUR_CLIENT_ID</string>
	<key>ANDROID_CLIENT_ID</key>
	<string>YOUR_ANDROID_CLIENT_ID.apps.googleusercontent.com</string>
	<key>API_KEY</key>
	<string>YOUR_IOS_API_KEY</string>
	<key>GCM_SENDER_ID</key>
	<string>YOUR_SENDER_ID</string>
	<key>PLIST_VERSION</key>
	<string>1</string>
	<key>BUNDLE_ID</key>
	<string>com.togetherly.love</string>
	<key>PROJECT_ID</key>
	<string>your-firebase-project-id</string>
	<key>STORAGE_BUCKET</key>
	<string>your-firebase-project-id.firebasestorage.app</string>
	<key>IS_ADS_ENABLED</key>
	<false></false>
	<key>IS_ANALYTICS_ENABLED</key>
	<false></false>
	<key>IS_APPINVITE_ENABLED</key>
	<true></true>
	<key>IS_GCM_ENABLED</key>
	<true></true>
	<key>IS_SIGNIN_ENABLED</key>
	<true></true>
	<key>GOOGLE_APP_ID</key>
	<string>1:YOUR_SENDER_ID:ios:YOUR_APP_ID</string>
	<key>DATABASE_URL</key>
	<string>https://your-firebase-project-id-default-rtdb.firebasedatabase.app</string>
</dict>
</plist>
