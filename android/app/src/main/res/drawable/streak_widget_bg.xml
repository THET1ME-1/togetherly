<?xml version="1.0" encoding="utf-8"?>
<!-- Тёплый «огненный» фон виджета серии (огонёк пары) -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:startColor="#FFB23E"
        android:centerColor="#FF6A3D"
        android:endColor="#F9417B"
        android:angle="135"
        android:type="linear" />
    <corners android:radius="24dp" />
    <stroke
        android:width="1dp"
        android:color="#33FFFFFF" />
</shape>
