<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center"
    android:weightSum="2"
    android:padding="6dp">

    <!-- ═══ Левая половина (user 0) ═══ -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/heart_2_0"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:scaleType="fitCenter"
                android:padding="14dp" />

            <TextView
                android:id="@+id/label_2_0"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:gravity="center"
                android:textSize="11sp"
                android:textColor="#FFFFFFFF"
                android:textStyle="bold"
                android:letterSpacing="0.02"
                android:shadowColor="#99000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="3"
                android:maxLines="1"
                android:ellipsize="end"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/mood_label_bg" />

        </LinearLayout>

        <!-- Аватарка в нижнем левом углу -->
        <ImageView
            android:id="@+id/avatar_0"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="bottom|start"
            android:layout_margin="6dp"
            android:scaleType="fitCenter"
            android:visibility="gone" />

    </FrameLayout>

    <!-- ═══ Правая половина (user 1) ═══ -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/heart_2_1"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:scaleType="fitCenter"
                android:padding="14dp" />

            <TextView
                android:id="@+id/label_2_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:gravity="center"
                android:textSize="11sp"
                android:textColor="#FFFFFFFF"
                android:textStyle="bold"
                android:letterSpacing="0.02"
                android:shadowColor="#99000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="3"
                android:maxLines="1"
                android:ellipsize="end"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/mood_label_bg" />

        </LinearLayout>

        <!-- Аватарка в нижнем правом углу -->
        <ImageView
            android:id="@+id/avatar_1"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="bottom|end"
            android:layout_margin="6dp"
            android:scaleType="fitCenter"
            android:visibility="gone" />

    </FrameLayout>

</LinearLayout>
