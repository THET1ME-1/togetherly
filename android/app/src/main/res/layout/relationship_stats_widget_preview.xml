<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/stats_widget_bg"
    android:clipToOutline="true"
    android:orientation="vertical"
    android:padding="8dp">

    <!-- Строка 1: Дней вместе + Воспоминания -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/stat_bg_pink"
            android:orientation="vertical"
            android:padding="12dp"
            android:gravity="start">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/stat_icon_circle"
                android:src="@drawable/ic_stat_calendar"
                android:padding="6dp"
                android:scaleType="fitCenter" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="739"
                android:textColor="#212121"
                android:textSize="22sp"
                android:textStyle="bold"
                android:maxLines="1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Дней вместе"
                android:textColor="#757575"
                android:textSize="10sp"
                android:maxLines="1" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:background="@drawable/stat_bg_blue"
            android:orientation="vertical"
            android:padding="12dp"
            android:gravity="start">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/stat_icon_circle"
                android:src="@drawable/ic_stat_photo"
                android:padding="5dp"
                android:scaleType="fitCenter" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="47"
                android:textColor="#212121"
                android:textSize="22sp"
                android:textStyle="bold"
                android:maxLines="1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Воспоминания"
                android:textColor="#757575"
                android:textSize="10sp"
                android:maxLines="1" />
        </LinearLayout>
    </LinearLayout>

    <!-- Строка 2: Рисунки + Скучаю -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/stat_bg_yellow"
            android:orientation="vertical"
            android:padding="12dp"
            android:gravity="start">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/stat_icon_circle"
                android:src="@drawable/ic_stat_brush"
                android:padding="5dp"
                android:scaleType="fitCenter" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="12"
                android:textColor="#212121"
                android:textSize="22sp"
                android:textStyle="bold"
                android:maxLines="1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Рисунки"
                android:textColor="#757575"
                android:textSize="10sp"
                android:maxLines="1" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:background="@drawable/stat_bg_purple"
            android:orientation="vertical"
            android:padding="12dp"
            android:gravity="start">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/stat_icon_circle"
                android:src="@drawable/ic_stat_heart"
                android:padding="5dp"
                android:scaleType="fitCenter" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="83"
                android:textColor="#212121"
                android:textSize="22sp"
                android:textStyle="bold"
                android:maxLines="1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Скучаю"
                android:textColor="#757575"
                android:textSize="10sp"
                android:maxLines="1" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
