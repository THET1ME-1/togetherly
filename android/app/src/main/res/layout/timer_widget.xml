<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/timer_widget_bg"
    android:clipToOutline="true">

    <!-- Декоративное большое сердце (фон, справа) -->
    <ImageView
        android:id="@+id/timer_bg_heart"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:layout_gravity="end|center_vertical"
        android:layout_marginEnd="8dp"
        android:alpha="0.12"
        android:src="@drawable/ic_heart_timer"
        android:scaleType="fitCenter" />

    <!-- Основной контент -->
    <LinearLayout
        android:id="@+id/timer_content_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <!-- Строка: маленькое сердце + название (скрывается в компактном режиме) -->
        <LinearLayout
            android:id="@+id/timer_header_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/timer_heart_icon"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_heart_timer"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/timer_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:text="Таймер"
                android:textSize="10sp"
                android:textColor="#C084B8"
                android:maxLines="1"
                android:ellipsize="end"
                android:letterSpacing="0.04" />
        </LinearLayout>

        <!-- Большое число дней — авто-подгон размера, чтобы не вылезало и
             не переносилось по цифрам при любом размере виджета -->
        <TextView
            android:id="@+id/timer_days_number"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="0"
            android:maxLines="1"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="18sp"
            android:autoSizeMaxTextSize="46sp"
            android:autoSizeStepGranularity="1sp"
            android:textStyle="bold"
            android:textColor="#B5488A"
            android:includeFontPadding="false"
            android:letterSpacing="-0.02" />

        <!-- Подпись "дней вместе" -->
        <TextView
            android:id="@+id/timer_days_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="дней вместе"
            android:textSize="11sp"
            android:textColor="#9B7AA8"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="0dp" />

        <!-- Дата -->
        <TextView
            android:id="@+id/timer_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="9sp"
            android:textColor="#C4A8D4"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="4dp"
            android:letterSpacing="0.02" />

    </LinearLayout>

</FrameLayout>
