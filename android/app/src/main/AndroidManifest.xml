<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- Permissions для QR-сканера -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />
    
    <!-- Permissions для фото/видео (Android 13+) -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <!-- Fallback для Android 12 и ниже -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <!-- Нужен для сохранения в галерею на Android 9 и ниже -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="28" />
    
    <!-- Permissions для геолокации -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- Карта «где мы»: шеринг локации с партнёром идёт через foreground-сервис
         (FOREGROUND_SERVICE_LOCATION) с постоянным уведомлением. Пока сервис
         активен, приложение считается «in use» и получает локацию в фоне БЕЗ
         ACCESS_BACKGROUND_LOCATION. Это разрешение намеренно НЕ объявляем, чтобы
         не проходить декларацию фоновой геолокации в Google Play (форма+видео).
         Вернуть только если понадобится headless-автозапуск (напр. после ребута
         без открытия приложения) — тогда нужен boot-receiver и декларация. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <!-- Пуш без FCM (§5): foreground-сервис типа dataSync держит SSE-подписку
         PbPushService живой, пока приложение свёрнуто/выгружено (flutter_foreground_task).
         WAKE_LOCK нужен для allowWakeLock (соединение не засыпает в Doze). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Мгновенная фоновая доставка БЕЗ FCM держится на живом WS-сокете в
         foreground-сервисе. Doze/«оптимизация батареи» рвут сетевой сокет даже
         у foreground-сервиса → пуши и виджеты обновляются только при открытии
         приложения. Это разрешение позволяет показать системный диалог
         «не оптимизировать» и держать соединение живым при свёрнутом приложении. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- Переопределяем неявные требования GPS, чтобы не блокировать планшеты и Chromebook -->
    <uses-feature android:name="android.hardware.location" android:required="false" />
    <uses-feature android:name="android.hardware.location.gps" android:required="false" />
    <uses-feature android:name="android.hardware.location.network" android:required="false" />
    
    <!-- Интернет (Firebase Storage) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- AdMob — разрешение для рекламного идентификатора -->
    <!-- Больше не удаляем — приложение использует рекламу (AdMob) -->
    
    <!-- Push-уведомления (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <!-- Вибрация для уведомлений -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Восстановление таймерного alarm'а после перезагрузки -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Точные будильники для живого виджета-лепестка -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    
    <!-- In-app billing for consumable products (coins) -->
    <uses-permission android:name="com.android.vending.BILLING" />

    <!-- Рекламный идентификатор для Google Mobile Ads (Android 13+/API 33).
         Без него ad ID заменяется нулями → ломается показ рекламы и аналитика. -->
    <uses-permission android:name="com.google.android.gms.permission.AD_ID" />
    
    <application
        android:label="Togetherly"
        android:name="${applicationName}"
        android:icon="@mipmap/launcher_icon"
        android:enableOnBackInvokedCallback="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:fullBackupContent="@xml/backup_rules"
        android:dataExtractionRules="@xml/data_extraction_rules">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <!-- MAIN/LAUNCHER вынесен в <activity-alias> ниже (кастомизация
                 иконки приложения по теме). Сами deep-link фильтры остаются
                 здесь, на MainActivity, и резолвятся независимо от того, какой
                 alias сейчас «лаунчер» — приглашения и виджет продолжают
                 работать при любой выбранной иконке. -->

            <!-- HomeWidget: открытие приложения по клику на виджет -->
            <intent-filter>
                <action android:name="es.antonborri.home_widget.action.LAUNCH" />
            </intent-filter>
            
            <!-- Deep link для приглашений -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <!-- Обработка loveapp://invite/{code} -->
                <data android:scheme="loveapp" android:host="invite" />
            </intent-filter>
            
            <!-- Web link: PocketBase-VPS (новый рабочий домен, обслуживает
                 assetlinks + /invite лендинг через pb_hooks/invite_web.pb.js) -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https"
                      android:host="togetherly.duckdns.org"
                      android:pathPrefix="/invite" />
            </intent-filter>

            <!-- Web link: Firebase Hosting (легаси-домен, для уже разосланных
                 ссылок; удалить после полного гашения Firebase) -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https"
                      android:host="togetherly-d4856.web.app"
                      android:pathPrefix="/invite" />
            </intent-filter>
        </activity>

