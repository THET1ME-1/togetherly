        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <!-- Иконка-сердечко для foreground-сервиса (flutter_foreground_task),
             чтобы в шторке не было чёрного квадрата / дефолтной иконки. -->
        <meta-data
            android:name="com.togetherly.love.notification_icon"
            android:resource="@drawable/ic_notification" />

        <!-- AdMob App ID -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-1956369312643059~3521559179"/>

        <!-- image_cropper: UCrop активность -->
        <activity
            android:name="com.yalantis.ucrop.UCropActivity"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar"/>

        <!-- HomeWidget: фоновый ресивер для обновления виджета когда процесс убит.
             С home_widget 0.8.1+ фоновая работа идёт через WorkManager
             (HomeWidgetBackgroundWorker), устаревший JobIntentService-сервис убран —
             он и вызывал краши enqueueWork/completeWork (IllegalArgumentException). -->
        <receiver android:name="es.antonborri.home_widget.HomeWidgetBackgroundReceiver"
            android:exported="false" />

        <!-- ═══ Виджет рабочего стола: Парный ═══ -->
        <receiver android:name=".LoveWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/love_widget_info" />
        </receiver>

        <!-- ═══ Виджет: Счётчик дней вместе ═══ -->
        <receiver android:name=".DaysCounterWidgetProvider"
            android:exported="true"
            android:label="Дни вместе">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/days_counter_widget_info" />
        </receiver>

        <!-- ═══ Виджет: Огонёк пары (серия дней подряд) ═══ -->
        <receiver android:name=".StreakWidgetProvider"
