        <!-- Receiver для ротации карусели фото-виджета -->
        <receiver android:name=".PhotoDayRotationReceiver" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.USER_PRESENT" />
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="com.togetherly.love.ACTION_ROTATE_TIMER" />
