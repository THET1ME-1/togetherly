             Каждый alias = вариант launcher-иконки, указывает на MainActivity.
             В рантайме включён ровно один (PackageManager.setComponentEnabledSetting
             через MethodChannel 'app_icon'). Дефолт — pink (enabled=true), остальные
             отключены. label у всех "Togetherly", меняется только icon/roundIcon. -->
        <activity-alias
            android:name=".IconPink"
            android:enabled="true"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_pink"
            android:roundIcon="@mipmap/ic_launcher_pink_round"
            android:label="Togetherly"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity-alias>
