# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store

# PII / секретные дампы — НИКОГДА не коммитить (инцидент: users.csv с хешами паролей)
*.csv
users.csv
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Keystore — приватный ключ подписи, никогда не коммитить
*.jks
*.keystore
key.properties

# iOS distribution signing key — приватный ключ, НИКОГДА не коммитить.
# Живёт в секретной переменной Codemagic CERTIFICATE_PRIVATE_KEY (см. codemagic.yaml).
ios/certs/*.pem

# Firebase client config — ключи проекта автора. В публичном репо лежат ТОЛЬКО
# *.example-шаблоны; реальные файлы подставляет каждый под свой проект.
ios/Runner/GoogleService-Info.plist
android/app/google-services.json

# Firebase Admin SDK private key — никогда не коммитить
scripts/serviceAccountKey.json
scripts/togetherly-d4856-firebase-adminsdk-*.json
scripts/node_modules/
functions/node_modules/

# Google Play publisher service-account key — никогда не коммитить
togetherly-d4856-*.json
play-publisher*.json

# Release APKs generated by release script
/release/

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
.firebase/hosting.aG9zdGluZw.cache

# Локальные настройки/состояние Claude Code — не версионируем (у каждого свои,
# содержат внутренние алиасы команд/почты — не для публичного репозитория).
.claude/
# iOS Xcode build artifacts (do not commit)
ios/build/

# Локальные билд-артефакты (APK/AAB) — не коммитим
dist/
