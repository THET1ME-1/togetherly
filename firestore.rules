rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Пользователи ──
    // Защита экономики: поля coins / ownedThemes / ownedIcons / devCoinsGranted /
    // lastDailyBonusAt / adRewardsDate / adRewardsToday — write-only для сервера
    // (Cloud Functions через admin SDK обходит правила). Клиент не может
    // изменять баланс или разблокированный контент напрямую — только читать.
    match /users/{userId} {
      function touchesProtected() {
        return request.resource.data.diff(resource.data).affectedKeys()
                 .hasAny(['coins', 'ownedThemes', 'devCoinsGranted',
                          'lastDailyBonusAt', 'adRewardsDate', 'adRewardsToday']);
      }

      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId
                    // При create запрещаем установку защищённых полей с клиента
                    && !request.resource.data.keys().hasAny(
                         ['coins', 'ownedThemes', 'ownedIcons', 'devCoinsGranted',
                          'lastDailyBonusAt', 'adRewardsDate', 'adRewardsToday']);
      allow delete: if request.auth != null && request.auth.uid == userId;
      // Свой документ — всё, КРОМЕ защищённых полей экономики;
      // чужой — только pairId/pairIds (приглашение).
      allow update: if request.auth != null
                    && (
                      (request.auth.uid == userId && !touchesProtected())
                      || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pairId', 'pairIds'])
                    );

      // IAP-токены: пишет только Cloud Function (admin SDK), клиент — только читает свои.
      // Нужны для idempotency: не дают начислить монеты дважды за один purchaseToken.
      match /iapPurchases/{purchaseToken} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; // только Cloud Function через admin SDK
      }

      // AdMob SSV idempotency-токены: аналогично — только сервер пишет.
      match /adRewards/{transactionId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }
    }

    // ── Коды приглашений ──
    match /inviteCodes/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid;
      // Удалять может владелец или принявший приглашение (уже вступил в группу кода)
      allow delete: if request.auth != null
                    && (resource.data.ownerUid == request.auth.uid
                        || request.auth.uid in get(/databases/$(database)/documents/groups/$(resource.data.groupId)).data.members);
    }

    // ── Пары (legacy) ──
    match /pairs/{pairId} {
      allow read: if request.auth != null
                  && (resource.data.user1 == request.auth.uid
                      || resource.data.user2 == request.auth.uid);
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
                    && (resource.data.user1 == request.auth.uid
                        || resource.data.user2 == request.auth.uid);
    }

    // ── Группы ──
    match /groups/{groupId} {
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.members;
      allow create: if request.auth != null;
      // Участник — обновляет что угодно.
      // Не-участник — может только добавить себя в members (join), и только это поле.
      allow update: if request.auth != null
                    && (request.auth.uid in resource.data.members
                        || (request.auth.uid in request.resource.data.members
                            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members'])));
      allow delete: if request.auth != null
                    && request.auth.uid in resource.data.members;

      function isMember() {
        return request.auth != null
            && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
      }

      // Воспоминания — только участники группы
      match /memories/{memoryId} {
        allow read, write: if isMember();

        match /comments/{commentId} {
          allow read, write: if isMember();
        }
      }

      match /moodCalendar/{userId}/{document=**} {
        allow read: if isMember();
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      match /widgetData/{userId} {
        allow read: if isMember();
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // Триггер для Cloud Function: каждый раз когда участник меняет mood/
      // status/message/music, в эту коллекцию пишется событие, которое
      // функция читает и шлёт партнёру FCM-update. Без правила каждая запись
      // падала PERMISSION_DENIED и спамила лог.
      match /widgetDataEvents/{eventId} {
        allow read: if isMember();
        allow create: if isMember()
                      && request.resource.data.senderUid == request.auth.uid;
      }

      match /reflections/{date} {
        allow read, write: if isMember();
      }

      match /missYouEvents/{eventId} {
        allow read: if isMember();
        allow create: if isMember();
      }

      // Триггер push-уведомления о новом сообщении чата. Без этого правила
      // запись падала PERMISSION_DENIED (catch-all ниже), Cloud Function
      // onChatMessageEvent не срабатывала и пуши не приходили. Документ
      // эфемерный — функция удаляет его сразу после рассылки FCM.
      match /chatEvents/{eventId} {
        allow read: if isMember();
        allow create: if isMember()
                      && request.resource.data.senderUid == request.auth.uid;
      }

      match /canvas/{canvasId} {
        allow read, write: if isMember();
      }

      match /canvas/{canvasId}/strokes/{strokeId} {
        allow read, create, update, delete: if isMember();
      }

      match /canvas/{canvasId}/live/{authorId} {
        allow read: if isMember();
        allow create, update: if isMember() && request.auth.uid == authorId;
        allow delete: if isMember() && request.auth.uid == authorId;
      }

      // Индикатор «кто сейчас на холсте». Раньше правила не было →
      // setCanvasPresence падал с permission-denied (само рисование работало).
      match /canvas/{canvasId}/presence/{userId} {
        allow read: if isMember();
        allow create, update, delete:
            if isMember() && request.auth.uid == userId;
      }

      match /canvasCatalogue/{canvasId} {
        allow read, write: if isMember();
      }

      match /canvases/{canvasId} {
        allow read: if isMember();
      }

      match /mascots/{mascotId} {
        allow read, write: if isMember();
      }
    }

    // Всё остальное — запрещено
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
